# ─── LLM ────────────────────────────────────────────────────────────────────
# OpenAI API key — used by all four agents
OPENAI_API_KEY=your_openai_api_key_here

# (Optional) Override the default model. Supports any litellm model string.
# Examples: gpt-4o | gpt-4-turbo | gpt-3.5-turbo | ollama/llama3
LLM_MODEL=gpt-4o

# ─── SEARCH ─────────────────────────────────────────────────────────────────
# SerpAPI key — https://serpapi.com/  (free tier: 100 searches/month)
SERPAPI_API_KEY=your_serpapi_api_key_here

# ─── WEATHER ────────────────────────────────────────────────────────────────
# OpenWeatherMap API key — https://openweathermap.org/api  (free tier available)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
